"      Q4_GJ=Q4*0.0036" "      OPR1=Q1_GJ*HP1" "      OPR2=Q2_GJ*LP1" 
"      OPR3=Q3_GJ*HP1" "      OPR4=Q4_GJ*HP1" "      OPREB=OPR1+OPR2+OPR3+OPR4" 
"      TRCOST=19928246.1" "      TCC=CC_TOT+REB_COST+R_COST+TRCOST" 
"      YOC=HCOST+OPREB+METHP+BENZP+CWCP" "      REV=MEBP" 
